# OmniRouter — Provider API Keys
# Copy to .env and fill in the keys for providers you want to use.
# Only providers with valid keys will be available for routing.

# Anthropic (Claude) — coding, reasoning, analysis
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, DALL-E, Whisper) — all-rounder
OPENAI_API_KEY=

# Google Gemini — fast, cheap, large context
GEMINI_API_KEY=

# Perplexity (Sonar) — real-time web research
PERPLEXITY_API_KEY=

# Moonshot / Kimi — 262K context, reasoning
MOONSHOT_API_KEY=

# Z.AI / GLM — budget tier, reasoning
ZAI_API_KEY=

# Budget limits (optional, in USD cents)
# OMNIROUTER_DAILY_BUDGET=500
# OMNIROUTER_MONTHLY_BUDGET=10000
