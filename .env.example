# OmniRouter — Provider API Keys
# Copy to .env and fill in the keys for providers you want to use.
# Only providers with valid keys will be available for routing.

# Anthropic (Claude) — coding, reasoning, analysis
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, DALL-E) — all-rounder
OPENAI_API_KEY=

# Google Gemini — fast, cheap, 1M context
GEMINI_API_KEY=

# xAI / Grok — strong reasoning, real-time knowledge
XAI_API_KEY=

# DeepSeek — top-tier coding & math, ultra-cheap
DEEPSEEK_API_KEY=

# Mistral — strong coding (Codestral), multilingual
MISTRAL_API_KEY=

# Perplexity (Sonar) — real-time web research
PERPLEXITY_API_KEY=

# Groq — ultra-fast inference (Llama, DeepSeek)
GROQ_API_KEY=

# Together AI — open-source models (Llama, DeepSeek)
TOGETHER_API_KEY=

# Cohere (Command R) — RAG, multilingual, enterprise
COHERE_API_KEY=

# Moonshot / Kimi — 262K context, reasoning
MOONSHOT_API_KEY=

# Z.AI / GLM — budget tier, reasoning
ZAI_API_KEY=

# Budget limits (optional, in USD cents)
# OMNIROUTER_DAILY_BUDGET=500
# OMNIROUTER_MONTHLY_BUDGET=10000
